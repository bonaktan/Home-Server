[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
CN = bonnybonnybonaktan.xyz

[v3_req]
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = bonnybonnybonaktan.xyz
DNS.2 = *.bonnybonnybonaktan.xyz
DNS.3 = internal.bonnybonnybonaktan.xyz
DNS.4 = *.internal.bonnybonnybonaktan.xyz
